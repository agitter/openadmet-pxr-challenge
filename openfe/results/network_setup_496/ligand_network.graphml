00b71\u00c0\u00dfO\u008d\u0097n\u0012;\u00c0;\u00dfO\u008d\u0097n#\u00c0?5^\u00baI\u00cc1\u00c0\u001f\u0085\u00ebQ\u00b8\u009e=\u00c0\u0087\u0016\u00d9\u00ce\u00f7\u0093$\u00c0\u009e\u00ef\u00a7\u00c6K\u00d72\u00c0\u00b6\u00f3\u00fd\u00d4x\u0089;\u00c0\u00a4p=\n\u00d7c#\u00c05^\u00baI\f\u00e22\u00c0fffff\u00c6&lt;\u00c0\u001dZd;\u00dfO$\u00c0j\u00bct\u0093\u0018\u00044\u00c0\u00e9&amp;1\b\u00ac\u00dc:\u00c0\u00ee|?5^:\"\u00c0/\u00dd$\u0006\u0081\u00154\u00c0\u00f0\u00a7\u00c6K7\t=\u00c0R\u00b8\u001e\u0085\u00eb\u00d1\"\u00c0?5^\u00baI\u00cc4\u00c07\u0089A`\u00e5\u00d0;\u00c0h\u0091\u00ed|?u0\u00c0\u00a0\u001a/\u00dd$\u00c6&amp;\u00c0\u00a2E\u00b6\u00f3\u00fd\u00f47\u00c0F\u00b6\u00f3\u00fd\u00d4x1\u00c0`\u00e5\u00d0\"\u00dby%\u00c0\u0012\u0083\u00c0\u00ca\u00a1E7\u00c0\u00aeG\u00e1z\u0014\u00ee0\u00c0)\\\u008f\u00c2\u00f5('\u00c0w\u00be\u009f\u001a/=9\u00c0}?5^\u00ba\u00892\u00c033333\u00f3$\u00c0Zd;\u00dfO-8\u00c0^\u00baI\f\u0002+2\u00c0\u0085\u00ebQ\u00b8\u001e\u0005&amp;\u00c0\u009c\u00c4 \u00b0rh9\u00c0D\u008bl\u00e7\u00fb\u00c93\u00c0;\u00dfO\u008d\u0097\u00ae#\u00c0V\u000e-\u00b2\u009d\u000f8\u00c0\u00e9&amp;1\b\u00ac\u00fc2\u00c0\u00fc\u00a9\u00f1\u00d2M\u00e2%\u00c0\u00d1\"\u00db\u00f9~\u008a:\u00c0\u00e5\u00d0\"\u00db\u00f9\u009e4\u00c0\u00f8S\u00e3\u00a5\u009b\u0084#\u00c0\u008f\u00c2\u00f5(\\/9\u00c0\f\u0002+\u0087\u001694\u00c0\u00b4\u00c8v\u00be\u009f\u009a$\u00c0H\u00e1z\u0014\u00aeg:\u00c0^K\u00c8\u0007=\u00fb'\u00c0:#J{\u0083O)\u00c0\u00d7\u00a3p=\nG;\u00c0g\u00d5\u00e7j+\u00b6%\u00c0+\u00f6\u0097\u00dd\u0093\u0087)\u00c0\u009c\u00a2#\u00b9\u00fc\u00c78\u00c0K\u00ea\u00044\u0011\u0096'\u00c0\u00dd$\u0006\u0081\u0095\u00c3&amp;\u00c0m\u00c5\u00fe\u00b2{\u00829\u00c0\u0014\u00d0D\u00d8\u00f0\u00b4)\u00c0d;\u00dfO\u008d\u0017+\u00c0*\u00a9\u0013\u00d0D\u00a87\u00c0333333)\u00c0V\u000e-\u00b2\u009d\u008f'\u00c0\\\u008f\u00c2\u00f5(L7\u00c0\u001c|a2U0/\u00c0\u00cd;N\u00d1\u0091\u00bc)\u00c0\u0010z6\u00ab&gt;\u00f79\u00c0@\u00a4\u00df\u00be\u000e\u00bc,\u00c0TR'\u00a0\u0089P'\u00c0\u00b9\u008d\u0006\u00f0\u0016\u0088:\u00c0P\u008d\u0097n\u0012\u00e3+\u00c04\u0080\u00b7@\u0082\u00c2+\u00c09\u00b4\u00c8v\u00be\u007f;\u00c0\u00fc\u00a9\u00f1\u00d2M\u00a2+\u00c0\u0089A`\u00e5\u00d0\"-\u00c0io\u00f0\u0085\u00c9\u00d49\u00c04\u00116&lt;\u00bd\u00d2(\u00c0\u0001M\u0084\rO/.\u00c0\u00fb\\m\u00c5\u00fe\"&lt;\u00c0\u00cb\u0010\u00c7\u00ba\u00b8\u00cd$\u00c0k\u009aw\u009c\u00a2\u0083/\u00c0\u00a4p=\n\u00d7\u00d3=\u00c0\u001b\u009e^)\u00cb\u00d0&amp;\u00c0\u00f9\u00a0g\u00b3\u00ea\u00b31\u00c0\u00dd\u00b5\u0084|\u00d0\u0013:\u00c0}\u00d0\u00b3Y\u00f5y\"\u00c0fffff\u00d61\u00c0\\\u008f\u00c2\u00f5(\u009c&gt;\u00c0\u00c9\u00e5?\u00a4\u00df\u00fe#\u00c0\u00a85\u00cd;N\u00b15\u00c0\u00e0\u009c\u0011\u00a5\u00bd\u0011&lt;\u00c0\u00da\u00ac\u00fa\\m\u00e5 \u00c0\u0093\u00a9\u0082QI\r5\u00c0)\u00cb\u0010\u00c7\u00baX;\u00c0M\u0084\rO\u00aft1\u00c0\u001b\u009e^)\u00cb\u00f0$\u00c0\u00a3#\u00b9\u00fc\u008746\u00c0^K\u00c8\u0007=k0\u00c0\u0094\u00f6\u0006_\u0098,(\u00c0D\u00fa\u00ed\u00eb\u00c0\u00f99\u00c0\u00ce\u0019Q\u00da\u001b\u001c4\u00c0\u00f8\u00c2d\u00aa`\u00d4\"\u00c0\u00d3Mb\u0010X\u00197\u00c0]m\u00c5\u00fe\u00b2\u00ab2\u00c0\u001c\u00eb\u00e26\u001a\u00c0&amp;\u00c0\u001c|a2U\u0080;\u00c0)\u00ed\r\u00be0\u00995\u00c0\u0084\rO\u00af\u0094\u0085\"\u00c0_\u0098L\u0015\u008c\u001a9\u00c0\u00dc\u00d7\u0081sF\u00e44\u00c0\u00c1\u00ca\u00a1E\u00b6s$\u00c0-!\u001f\u00f4lF;\u00c0", {}], "molprops": {"CNNaffinity": 6.45633316, "CNNscore": 0.697324097, "atom.dprop.PartialCharge": "-0.14043774254620076 -0.092204978540539745 0.095236743018031117 -0.46541001446545122 0.69881714336574074 -0.58792894132435325 0.095236743018031117 -0.092204978540539745 0.67551768772304055\n-0.57509826667606834 -0.48474751956760881 0.058718012794852253 -0.14354205675423146 -0.13903000004589558 -0.090682661011815074 0.065386617705225941 0.037559414431452748\n-0.33270513065159318 -0.3341863954812288 0.320460686609149 -0.016835758313536644 -0.1302229667454958 -0.