\u00a3p=\u008a2\u00c0\u00f2\u00d2Mb\u0010X$\u00c0\u00f8S\u00e3\u00a5\u009b\u00e48\u00c0\u00d3Mb\u0010X\u00190\u00c0sh\u0091\u00ed|\u00bf(\u00c0L7\u0089A`\u00857\u00c0\u00f0\u00a7\u00c6K7\u00a91\u00c0\u001b/\u00dd$\u0006\u0081&amp;\u00c0j\u00bct\u0093\u0018\u00a48\u00c0P\u008d\u0097n\u0012\u00830\u00c0\u00f8S\u00e3\u00a5\u009b\u0004*\u00c0\u0085\u00ebQ\u00b8\u001e\u00a58\u00c0\u00c5 \u00b0rhq1\u00c0\u00f8S\u00e3\u00a5\u009b\u00c4(\u00c0\u0096C\u008bl\u00e7[9\u00c0\u00dfO\u008d\u0097nr3\u00c0\u000e-\u00b2\u009d\u00efg$\u00c0\u00f8S\u00e3\u00a5\u009b$:\u00c0\u00c5 \u00b0rh\u00913\u00c0X9\u00b4\u00c8v&gt;'\u00c0\u00fc\u00a9\u00f1\u00d2M\u00c2:\u00c0\u00a8\u00c6K7\u0089\u00e12\u00c0\u00d7\u00a3p=\n\u0097\"\u00c0\u00a8\u00c6K7\u0089A;\u00c0\u00fc\u00a9\u00f1\u00d2M\u00e24\u00c0\u00a0\u001a/\u00dd$\u0086#\u00c0D\u008bl\u00e7\u00fb\u00c99\u00c0\u0080H\u00bf}\u001d\u00980\u00c0~\u001d8gD\u00e9\u0015\u00c0\u00b7\u00d1\u0000\u00de\u0002\u00b94\u00c0\u00dch\u0000o\u0081d/\u00c09EGr\u00f9\u00cf\u0015\u00c0\u0010z6\u00ab&gt;G6\u00c0\u00cb\u0010\u00c7\u00ba\u00b8}1\u00c0\u00b4\u00c8v\u00be\u009f\u001a\u0016\u00c0\u0010z6\u00ab&gt;G6\u00c0\u00ac\u001cZd;\u00bf.\u00c0\u000eO\u00af\u0094e\u00e8!\u00c0k\u009aw\u009c\u00a2S6\u00c0\u0013\u00f2A\u00cffU-\u00c0\u00fb\u00cb\u00ee\u00c9\u00c3B\u001d\u00c0t\u00b5\u0015\u00fb\u00cb\u00ae6\u00c0\u00b2\u009d\u00ef\u00a7\u00c6\u000b-\u00c033333s\u0017\u00c0;\u00dfO\u008d\u0097N4\u00c0\u00e3\u00a5\u009b\u00c4 0,\u00c0\u000e-\u00b2\u009d\u00efG$\u00c0\u00b7b\u007f\u00d9=\u00c94\u00c0\u0089A`\u00e5\u00d0b*\u00c0|\u00f2\u00b0Pk\u00da\u0017\u00c0j\u00deq\u008a\u008e42\u00c0\u00cc\u007fH\u00bf}\u009d(\u00c0\u00b3{\u00f2\u00b0PK \u00c0\u0089\u00d2\u00de\u00e0\u000bc1\u00c0\u008e\u0006\u00f0\u0016H03\u00c0\u00c5 \u00b0rh\u0091 \u00c0tF\u0094\u00f6\u0006\u001f8\u00c0\u00b5\u0015\u00fb\u00cb\u00ee\u00190\u00c0\u00d6\u00c5m4\u0080\u00f7+\u00c0\u00fb\u00cb\u00ee\u00c9\u00c3\u00f28\u00c0R'\u00a0\u0089\u00b0\u00a13\u00c0\\\u008f\u00c2\u00f5(\u00bc(\u00c02\u00e6\u00ae%\u00e4\u00f39\u00c0\u00d3Mb\u0010Xy4\u00c0\u0099\u00bb\u0096\u0090\u000fZ'\u00c0\u00c5 \u00b0rha;\u00c0W\u00ec/\u00bb'\u00af2\u00c0\u00d5x\u00e9&amp;1\u00a8'\u00c0\u00c5 \u00b0rha;\u00c0'\u00a0\u0089\u00b0\u00e1Y2\u00c0\u0016\u00fb\u00cb\u00ee\u00c9\u00e3 \u00c0&gt;yX\u00a85\u00cd:\u00c0\u0002\u009a\b\u001b\u009e.2\u00c0\u00ae\u00d8_vO\u00be#\u00c0\u008cJ\u00ea\u00044\u00e1;\u00c0\u00be\u009f\u001a/\u00dd\u00b43\u00c0+\u0087\u0016\u00d9\u00ce\u00d7!\u00c0\u008cJ\u00ea\u00044\u00e1;\u00c0\u00ac\u00ad\u00d8_v\u00ff4\u00c0Nb\u0010X9t#\u00c05^\u00baI\f\u00b28\u00c0\u0088c]\u00dcF\u00135\u00c0\u009e^)\u00cb\u0010\u0087!\u00c0\u00a1\u00f81\u00e6\u00ae5:\u00c0|a2U0\u009a5\u00c0\u0083\u00c0\u00ca\u00a1E\u00f6$\u00c0\u00a1\u00f81\u00e6\u00ae5:\u00c0", {}], "molprops": {"CNNaffinity": 7.11878967, "CNNscore": 0.896558404, "atom.dprop.PartialCharge": "0.090142256823246891 -0.47021632710390765 0.14868540247983258 -0.11145190963440615 -0.094481260272795742 -0.08053497293883044 -0.13552378931933123 -0.019227661880786003\n-0.088355042728716915 0.23487953027791303 -0.35788505593233783 0.59398621996945666 -0.57092052021914197 0.45487869462079328 -0.54966031828814221 -0.34558808127337176 0.59438646515912341\n0.088411174026196415 -0.64935242453509046 0.021106218230789123 0.55277008494443225 -0.53978335181170178 -0.022132825794751228 -0.088226631972128933 -0.088226631972128933\n-0.088226631972128933 0.044051549640362675 0.044051549640362675 0.044051549640362675 0.069353579786484654 0.069353579786484654 0.14590506931847852 0.14506331762379926 0.14286162635392469\n0.14909375390118879 0.17242460629052442 0.068217485454743321 0.04734663596457761 0.04734663596457761 0.04734663596457761 0.04734663596457761 0.04734663596457761 0.04734663596457761\n0.04734663596457761 0.04734663596457761 0.04734663596457761", "cluster_id": 488, "ligand_id": "T135", "minimizedAffinity": -9.47856998, "ofe-name": "OADMET-0006477", "source_pdb_id": "7rio", "source_pose_rank": 1, "source_smiles": "CN(CC1=CC